---
source: crates/loom-core/src/agent/claude_code.rs
expression: content
---
{
  "additionalDirectories": [
    "/loom/my-feature/dsp-api",
    "/loom/my-feature/dsp-das"
  ],
  "effortLevel": "high",
  "enabledPlugins": {
    "pkm@test-marketplace": true
  },
  "extraKnownMarketplaces": {
    "test-marketplace": {
      "source": {
        "repo": "org/test-plugins",
        "source": "github"
      }
    }
  },
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash(cargo test *)",
      "Bash(gh issue *)"
    ]
  },
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "enabled": true,
    "excludedCommands": [
      "docker"
    ],
    "filesystem": {
      "allowWrite": [
        "//code/dasch-swiss/dsp-api/.git",
        "//code/dasch-swiss/dsp-das/.git",
        "~/.cargo",
        "~/.config/loom"
      ]
    },
    "network": {
      "allowedDomains": [
        "docs.rs",
        "github.com"
      ]
    }
  }
}
